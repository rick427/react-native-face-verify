{
  "name": "react-native-face-verify-example",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "xcodebuild ONLY_ACTIVE_ARCH=YES -workspace ios/FaceVerifyExample.xcworkspace -UseNewBuildSystem=YES -scheme FaceVerifyExample -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -quiet",
    "build:android": "cd android && ./gradlew assembleDebug -DtestBuildType=debug -Dorg.gradle.jvmargs=-Xmx4g"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@rick427/react-native-face-verify": "*",
    "expo": "~55.0.23",
    "expo-image-picker": "~16.0.6",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-svg": "^15.0.0",
    "react-native-vision-camera": "^4.0.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets-core": "^1.3.3"
  },
  "private": true,
  "devDependencies": {
    "expo-dev-client": "~55.0.32",
    "react-native-builder-bob": "^0.41.0",
    "react-native-monorepo-config": "^0.3.3"
  }
}
